{
  "name": "weitou-caiwu",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "author": {
    "name": "Xiaoyang"
  },
  "description": "",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:pack": "SET VITE_IS_ELECTRON=true&& vite build && electron-builder --dir",
    "electron:dist": "SET VITE_IS_ELECTRON=true&& vite build && electron-builder",
    "electron:prod": "SET VITE_IS_ELECTRON=true&& SET VITE_IS_PROD=true&& vite build && electron-builder"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.xiaoyang.weitoucaiwu",
    "compression": "maximum",
    "asar": true,
    "productName": "微投财务",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.map",
      "!**/.DS_Store",
      "!node_modules//*",
      "!/node_modules//*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!**/*.md",
      "!src/**",
      "!public/**",
      "!{test,tests,__tests__}/**"
    ],
    "directories": {
      "buildResources": "build"
    },
    "icon": "build/icon",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "displayLanguageSelector": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "artifactName": "${productName} ${version}.${ext}",
      "shortcutName": "${productName}",
      "uninstallDisplayName": "${productName} 卸载程序"
    }
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.13.5",
    "clipboard-copy": "^4.0.1",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4",
    "vue-toastification": "^2.0.0-rc.5",
    "vuetify": "^3.11.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.2.4",
    "vite-plugin-vuetify": "^2.1.2",
    "wait-on": "^9.0.5"
  }
}
